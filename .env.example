# ========================
# APP
# ========================
APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:sr/bEkr5bw82HHf6xZ9L1EB/VKIgnBe5i8mFpDxBVkQ=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ========================
# DATABASE
# ========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=law_doc
DB_USERNAME=root
DB_PASSWORD=

# ========================
# QUEUE + CACHE (LOCAL DEV)
# ========================
QUEUE_CONNECTION=sync          # use sync for local development
CACHE_DRIVER=file              # use file cache for local dev
CACHE_STORE=file               # same as above

# when production
# QUEUE_CONNECTION=redis
# CACHE_DRIVER=redis
# CACHE_STORE=redis
# ========================
# REDIS (DISABLED FOR LOCAL DEV)
# ========================
REDIS_CLIENT=phpredis          # leave default; will not be used
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ========================
# SESSION
# ========================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ========================
# BROADCAST & FILES
# ========================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ========================
# MAIL
# ========================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ========================
# AWS (optional, leave empty)
# ========================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========================
# VITE
# ========================
VITE_APP_NAME="${APP_NAME}"